# --- Mailchimp (recommended) ---
# From Audience → Signup forms → Embedded forms: copy the form action URL, e.g.
# https://YOURDC.list-manage.com/subscribe/post?u=XXXXXXXX&id=YYYYYYYY
#
# VITE_MAILCHIMP_DC=us21
# VITE_MAILCHIMP_U=XXXXXXXX
# VITE_MAILCHIMP_AUDIENCE_ID=YYYYYYYY
#
# If your embed HTML includes <input type="hidden" name="f_id" ...>, add:
# VITE_MAILCHIMP_F_ID=...

# --- Optional generic endpoint (used only when Mailchimp vars above are unset) ---
# VITE_NEWSLETTER_ENDPOINT=https://example.com/api/subscribe
